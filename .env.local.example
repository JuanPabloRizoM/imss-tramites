# Variables de entorno del proyecto tramites-imss.
# Copia este archivo a .env.local y llena los valores.
# NUNCA pongas claves reales en este archivo — se versiona en Git.

# Supabase: usadas en el navegador (públicas).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase: usada SOLO en el servidor (API routes). No exponer al navegador.
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic: usada SOLO en el servidor (API routes). No exponer al navegador.
ANTHROPIC_API_KEY=
